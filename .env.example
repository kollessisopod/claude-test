# Copy to .env and adjust. docker-compose reads this file automatically.

# --- PostgreSQL ---
POSTGRES_DB=ostquiz
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Backend ---
ASPNETCORE_ENVIRONMENT=Development
# Admin endpoints require this key in the X-Admin-Key header.
ADMIN_KEY=dev-admin-key
# HMAC secret for signing player progression tokens. Change this in production.
TOKENS_SECRET=dev-insecure-token-secret-change-me
# Seed sample games + today's puzzle on startup (true/false).
SEED_ENABLED=true

# --- RAWG metadata API ---
# Get a free key at https://rawg.io/apidocs . Optional: seed data works without it,
# but /api/admin/games/import and lazy publisher/developer enrichment need it.
RAWG_API_KEY=
